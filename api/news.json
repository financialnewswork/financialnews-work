---
layout: null
---
{
  "name": "{{ site.title }}",
  "description": {{ site.description | jsonify }},
  "url": "{{ site.url }}",
  "feed_url": "{{ site.url }}/feed.xml",
  "updated": "{{ site.time | date_to_xmlschema }}",
  "total_articles": {{ site.news | size }},
  "articles": [
    {% assign sorted_news = site.news | sort: 'date' | reverse %}
    {% for article in sorted_news %}
    {
      "title": {{ article.title | jsonify }},
      "date": "{{ article.date | date: '%Y-%m-%d' }}",
      "url": "{{ article.url | absolute_url }}",
      "company": {{ article.company | jsonify }},
      "tags": {{ article.tags | jsonify }},
      "source_url": {{ article.source_url | jsonify }},
      "excerpt": {{ article.content | strip_html | truncatewords: 50 | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
