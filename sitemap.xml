---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9" xmlns:news="http://www.google.com/schemas/sitemap-news/0.9">
  <url>
    <loc>{{ site.url }}/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>{{ site.url }}/news/</loc>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>{{ site.url }}/about/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
  <url>
    <loc>{{ site.url }}/submit/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.4</priority>
  </url>
  {% assign sorted_news = site.news | sort: 'date' | reverse %}
  {% for article in sorted_news %}
  <url>
    <loc>{{ article.url | absolute_url }}</loc>
    <lastmod>{{ article.date | date: '%Y-%m-%d' }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
    <news:news>
      <news:publication>
        <news:name>{{ site.title }}</news:name>
        <news:language>en</news:language>
      </news:publication>
      <news:publication_date>{{ article.date | date: '%Y-%m-%d' }}</news:publication_date>
      <news:title>{{ article.title | xml_escape }}</news:title>
      <news:keywords>{{ article.tags | join: ', ' | xml_escape }}</news:keywords>
    </news:news>
  </url>
  {% endfor %}
</urlset>
